        <Expression Value="Result"/>
        <DisplayFormat ArrayLineInherit="False" MultiLineInherit="False" MultiLineForceSingleLineThresholdStructFld="32" MultiLineForceSingleLineThresholdArrayLen="32" MultiLineForceSingleLineReverseDepth="32" IsMemDump="True"/>
      </Item>
      <Item>
        <Expression Value="cmd"/>
        <DisplayFormat NumInherit="False" Num="vdfBaseHex"/>
      </Item>
      <Item>
        <Expression Value="pkt"/>
        <DisplayFormat IsMemDump="True"/>
      </Item>
      <Item>
        <Expression Value="size"/>
        <DisplayFormat NumInherit="False" Num="vdfBaseHex"/>
      </Item>
      <Item>
        <Expression Value="result"/>
        <DisplayFormat NumInherit="False" Num="vdfBaseHex" ArrayNavBarInherit="False"/>
      </Item>
      <Item>
        <Expression Value="DI"/>
        <DisplayFormat ArrayNavBarInherit="False"/>
      </Item>
      <Item>
        <Expression Value="inode"/>
      </Item>
      <Item>
        <Expression Value="aMode"/>
        <DisplayFormat NumInherit="False" Num="vdfBaseOct"/>
      </Item>
      <Item>
        <Expression Value="first_offset"/>
      </Item>
      <Item>
        <Expression Value="tmpData"/>
      </Item>
      <Item>
        <Expression Value="fActiveSB"/>
      </Item>
      <Item>
        <Expression Value="FModelID"/>
        <DisplayFormat NumInherit="False" Num="vdfBaseHex"/>
      </Item>
    </Watches>
  </Debugging>
</CONFIG>
